      "outputs": [],
      "source": [
        "# ====================== Global Configuration ======================\n",
        "INPUT_TRAIN = \"/content/train_with_predictions.csv\"\n",
        "INPUT_TEST = \"/content/test_with_predictions.csv\"\n",
        "OUTPUT_DIR = \"outputs\"\n",
        "\n",
        "# Alias and style files\n",
        "SEED_FILE_PATH = \"/content/aliases_seed_en.json\"\n",
        "ALIASES_ML_PATH = \"/content/aliases_multilang.json\"\n",
        "STYLE_TO_GLAMI_PATH = \"/content/style_to_glami_names.json\"\n",
        "CACHE_PATH = \".cache/translate_cache.json\"\n",
        "\n",
        "# Style detection parameters\n",
        "STYLE_TEXT_COLS = [\"final_input_text\", \"category_name\"]\n",
        "STYLE_MODEL_NAME = \"sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2\"\n",
        "STYLE_RULE_BOOST = True\n",
        "STYLE_USE_NEGATIVES = True\n",
        "STYLE_RULE_BOOST_VALUE = 0.05\n",
        "STYLE_NEG_PENALTY_VALUE = 0.2\n",
        "\n",
        "# Material extraction parameters\n",
        "NER_MODEL_NAME = \"Davlan/xlm-roberta-base-ner-hrl\"\n",
        "FALLBACK_NER_MODEL_NAME = \"Davlan/bert-base-multilingual-cased-ner-hrl\"\n",
        "NER_SCORE_THRESHOLD = 0.45\n",
        "ENABLE_NER = True\n",
        "\n",
        "# Color extraction parameters\n",
        "COLOR_SCORE_THRESHOLD = 0.35\n",
        "\n",
        "# Pattern extraction parameters\n",
        "KEYBERT_TOP_N = 8\n",
        "PATTERN_THRESHOLD = 0.33\n",
        "kw_model = None\n",
        "\n",
        "def get_keybert_model():\n",
        "    global kw_model\n",
        "    if kw_model is None:\n",
        "        try:\n",
        "            print(\"🤖 Initializing KeyBERT model (this may take a moment)...\")\n",
        "            from sentence_transformers import SentenceTransformer\n",
        "            model = SentenceTransformer('all-MiniLM-L6-v2')\n",
        "            kw_model = KeyBERT(model=model)\n",
        "            print(\"✓ KeyBERT model initialized\")\n",
        "        except Exception as e:\n",
        "            print(f\"⚠️ KeyBERT initialization failed, using rule-based extraction only\")\n",
        "            kw_model = None\n",
        "    return kw_model"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 22,
      "metadata": {
        "id": "qToOvvmWq0zd"
      },
      "outputs": [],
      "source": [
        "# ====================== Multilingual Mapping ======================\n",
        "GEO_TO_LANG = {\n",
        "    \"cz\": \"cs\",  # Czech\n",
        "    \"sk\": \"sk\",  # Slovak\n",
        "    \"gr\": \"el\",  # Greek\n",
        "    \"hu\": \"hu\",  # Hungarian\n",
        "    \"si\": \"sl\",  # Slovenian\n",
        "    \"lt\": \"lt\",  # Lithuanian\n",
        "    \"lv\": \"lv\",  # Latvian\n",
        "    \"hr\": \"hr\",  # Croatian\n",
        "    \"bg\": \"bg\",  # Bulgarian\n",
        "    \"ee\": \"et\",  # Estonian\n",
        "    \"tr\": \"tr\",  # Turkish\n",
        "    \"ro\": \"ro\",  # Romanian\n",
        "    \"es\": \"es\",  # Spanish\n",
        "}\n",
        "\n",
        "# Terms that should NOT be translated\n",
        "DO_NOT_TRANSLATE = {\n",
        "    \"lolita\", \"sweet lolita\", \"gothic lolita\", \"classic lolita\", \"egl\", \"ouji\",\n",
        "    \"gyaru\", \"gal\", \"agejo\", \"onee gyaru\", \"hime gyaru\", \"amekaji\", \"kogal\",\n",
        "    \"manba\", \"tsuyome\", \"ganguro\",\n",
        "    \"kireime\", \"kireime casual\", \"mode-kei\", \"mode\",\n",
        "    \"streetwear\", \"techwear\", \"athleisure\", \"preppy\",\n",
        "    \"grunge\", \"punk\", \"glam rock\", \"hard rock\", \"rock style\",\n",
        "    \"retro\", \"vintage\", \"boho\", \"boho chic\"\n",
        "}\n",
        "\n",
        "DEFAULT_NEGATIVES = {\n",
        "    \"Lolita\": [\"lolita lempicka\"],\n",
        "    \"Rock\": [\"rocket\", \"rocking\", \"rockefeller\"],\n",
        "}"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 23,
      "metadata": {
        "id": "udCyHnqiq0zd"
      },
      "outputs": [],
      "source": [
        "# ====================== Utility Functions ======================\n",
        "def os_make_dirs_safe(path):\n",
        "    \"\"\"Create directories safely for a given file path.\"\"\"\n",
        "    directory = os.path.dirname(path)\n",
        "    if directory:\n",
        "        os.makedirs(directory, exist_ok=True)\n",
        "\n",
        "def read_csv_robust(path):\n",
        "    \"\"\"Read CSV with multiple encoding fallbacks.\"\"\"\n",
        "    last_error = None\n",
        "    for enc in [\"utf-8\", \"utf-8-sig\"]:\n",
        "        try:\n",
        "            df = pd.read_csv(path, encoding=enc, encoding_errors=\"replace\",\n",
        "                           engine=\"python\", on_bad_lines=\"skip\")\n",
        "            return df\n",
        "        except Exception as e:\n",
        "            last_error = e\n",
        "    raise RuntimeError(f\"Failed to read CSV: {last_error}\")\n",
        "\n",
        "def clean_text(x):\n",
        "    \"\"\"Clean and normalize raw text input.\"\"\"\n",
        "    x = \"\" if pd.isna(x) else str(x)\n",
        "    x = fix_text(x)\n",
        "    x = re.sub(r\"<[^>]+>\", \" \", x)\n",
        "    x = re.sub(r\"http\\S+|www\\.\\S+\", \" \", x)\n",
        "    x = x.replace(\"\\\\n\", \" \").replace(\"\\\\r\", \" \").replace(\"\\\\t\", \" \")\n",
        "    x = re.sub(r\"\\s+\", \" \", x).strip().lower()\n",
        "    return x\n",
        "\n",
        "def norm_text(s: str) -> str:\n",
        "    \"\"\"Basic string normalization.\"\"\"\n",
        "    if s is None or s != s:\n",
        "        return \"\"\n",
        "    return str(s).strip()\n",
        "\n",
        "def dedup_keep_order(items):\n",
        "    \"\"\"Deduplicate list while preserving order.\"\"\"\n",
        "    seen = set()\n",
        "    out = []\n",
        "    for x in items:\n",
        "        x2 = x.strip()\n",
        "        if not x2:\n",
        "            continue\n",
        "        if x2 not in seen:\n",
        "            out.append(x2)\n",
        "            seen.add(x2)\n",
        "    return out"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 24,
      "metadata": {
        "id": "idHo3fwlq0zd"
      },
      "outputs": [],
      "source": [
        "# ====================== 1. Multilingual Alias Generation ======================\n",
        "def load_cache(path=CACHE_PATH):\n",
        "    \"\"\"Load translation cache from JSON file.\"\"\"\n",
        "    if os.path.exists(path):\n",
        "        try:\n",
        "            with open(path, \"r\", encoding=\"utf-8\") as f:\n",
        "                return json.load(f)\n",
        "        except Exception:\n",
        "            return {}\n",
        "    return {}\n",
        "\n",
        "def save_cache(cache, path=CACHE_PATH):\n",
        "    \"\"\"Save translation cache to JSON file.\"\"\"\n",
        "    cache_dir = os.path.dirname(path)\n",
        "    if cache_dir:\n",
        "        os.makedirs(cache_dir, exist_ok=True)\n",
        "    with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(cache, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "def translate_phrase(phrase, tgt_lang_code, cache, sleep=0.2, retries=3):\n",
        "    \"\"\"Translate phrase with caching and retry logic.\"\"\"\n",
        "    key = f\"{phrase}|||{tgt_lang_code}\"\n",
        "    if key in cache:\n",
        "        return cache[key]\n",
        "    if phrase.lower() in DO_NOT_TRANSLATE:\n",
        "        cache[key] = phrase.lower()\n",
        "        return cache[key]\n",
        "\n",
        "    for i in range(retries):\n",
        "        try:\n",
        "            translation = GoogleTranslator(source=\"en\", target=tgt_lang_code).translate(phrase)\n",
        "            translation = translation.lower().strip()\n",
        "            cache[key] = translation\n",
        "            time.sleep(sleep)\n",
        "            return translation\n",
        "        except Exception as e:\n",
        "            time.sleep(0.6 * (i + 1))\n",
        "\n",
        "    cache[key] = phrase.lower()\n",
        "    return cache[key]\n",
        "\n",
        "def build_multilang_aliases(seed_path=SEED_FILE_PATH, out_path=ALIASES_ML_PATH, target_geos=None):\n",
        "    \"\"\"Build multilingual aliases from English seed file.\"\"\"\n",
        "    if target_geos is None:\n",
        "        target_geos = [\"cz\",\"sk\",\"gr\",\"hu\",\"si\",\"lt\",\"lv\",\"hr\",\"bg\",\"ee\",\"tr\",\"ro\",\"es\"]\n",
        "\n",
        "    if not os.path.exists(seed_path):\n",
        "        raise FileNotFoundError(f\"English alias seed file not found: {seed_path}\")\n",
        "\n",
        "    with open(seed_path, \"r\", encoding=\"utf-8\") as f:\n",
        "        data = json.load(f)\n",
        "\n",
        "    for geo in target_geos:\n",
        "        if geo not in GEO_TO_LANG:\n",
        "            raise ValueError(f\"Unknown geo code '{geo}' - add to GEO_TO_LANG\")\n",
        "\n",
        "    cache = load_cache()\n",
        "    for style, obj in data.items():\n",
        "        en_aliases = [x.lower().strip() for x in obj.get(\"aliases\", {}).get(\"en\", []) if str(x).strip()]\n",
        "        en_aliases = dedup_keep_order(en_aliases)\n",
        "        new_aliases = {\"en\": en_aliases}\n",
        "\n",
        "        for geo in target_geos:\n",
        "            lang_code = GEO_TO_LANG[geo]\n",
        "            translated = [translate_phrase(word, lang_code, cache) for word in en_aliases]\n",
        "            translated = dedup_keep_order(translated)\n",
        "            new_aliases[geo] = translated\n",
        "\n",
        "        data[style][\"aliases\"] = new_aliases\n",
        "\n",
        "    save_cache(cache)\n",
        "    os_make_dirs_safe(out_path)\n",
        "    with open(out_path, \"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(data, f, ensure_ascii=False, indent=2)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 25,
      "metadata": {
        "id": "EGzFc2jVq0ze"
      },
      "outputs": [],
      "source": [
        "# ====================== 2. Compile Style → GLAMI Names ======================\n",
        "def normalize_space(s: str) -> str:\n",
        "    \"\"\"Normalize whitespace in string.\"\"\"\n",
        "    s = s.strip().lower()\n",
        "    s = re.sub(r\"\\s+\", \" \", s)\n",
        "    return s\n",
        "\n",
        "def alias_to_regex(alias: str) -> str:\n",
        "    \"\"\"Convert alias to regex pattern.\"\"\"\n",
        "    a = normalize_space(alias)\n",
        "    a = re.escape(a)\n",
        "    a = a.replace(r\"\\ \", r\"[\\s\\-_]?\")\n",
        "    return r\"\\b\" + a + r\"\\b\"\n",
        "\n",
        "def add_unidecode_variant(alias: str) -> list:\n",
        "    \"\"\"Add ASCII variant for accented characters.\"\"\"\n",
        "    try:\n",
        "        ascii_alias = unidecode(alias)\n",
        "    except Exception:\n",
        "        ascii_alias = alias\n",
        "\n",
        "    if ascii_alias and ascii_alias != alias:\n",
        "        return [alias_to_regex(alias), alias_to_regex(ascii_alias)]\n",
        "    return [alias_to_regex(alias)]\n",
        "\n",
        "def build_style_to_glami_names(input_ml_path=ALIASES_ML_PATH, out_path=STYLE_TO_GLAMI_PATH):\n",
        "    \"\"\"Compile regex patterns and negative rules for style matching.\"\"\"\n",
        "    if not os.path.exists(input_ml_path):\n",
        "        raise FileNotFoundError(f\"Multilingual alias file not found: {input_ml_path}\")\n",
        "\n",
        "    with open(input_ml_path, \"r\", encoding=\"utf-8\") as f:\n",
        "        data = json.load(f)\n",
        "\n",
        "    compiled = {}\n",
        "    for style, obj in data.items():\n",
        "        aliases_by_lang = obj.get(\"aliases\", {})\n",
        "        regex_patterns = []\n",
        "\n",
        "        for lang_key, words in aliases_by_lang.items():\n",
        "            for word in words:\n",
        "                if not word or not str(word).strip():\n",
        "                    continue\n",
        "                patterns = add_unidecode_variant(str(word).strip())\n",
        "                regex_patterns.extend(patterns)\n",
        "\n",
        "        regex_patterns = dedup_keep_order(regex_patterns)\n",
        "        negatives = obj.get(\"negatives\", [])\n",
        "\n",
        "        if style in DEFAULT_NEGATIVES:\n",
        "            negatives = list(dict.fromkeys(negatives + DEFAULT_NEGATIVES[style]))\n",
        "\n",
        "        compiled[style] = {\n",
        "            \"aliases\": aliases_by_lang,\n",
        "            \"regex\": regex_patterns,\n",
        "            \"negatives\": negatives\n",
        "        }\n",
        "\n",
        "    os_make_dirs_safe(out_path)\n",
        "    with open(out_path, \"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(compiled, f, ensure_ascii=False, indent=2)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 26,
      "metadata": {
        "id": "C65W6ffFq0ze"
      },
      "outputs": [],
      "source": [
        "# ====================== 3. Zero-shot Style Prediction ======================\n",
        "def load_json(path):\n",
        "    \"\"\"Load JSON file.\"\"\"\n",
        "    with open(path, \"r\", encoding=\"utf-8\") as f:\n",
        "        return json.load(f)\n",
        "\n",
        "def merge_aliases(style_to_glami: Dict, aliases_en: Dict, aliases_ml: Dict) -> Tuple[Dict, Dict, Dict]:\n",
        "    \"\"\"Merge aliases from all sources.\"\"\"\n",
        "    aliases_by_style_lang = defaultdict(lambda: defaultdict(list))\n",
        "    negatives_by_style = defaultdict(list)\n",
        "    regex_by_style = defaultdict(list)\n",
        "\n",
        "    for style, obj in style_to_glami.items():\n",
        "        if isinstance(obj.get(\"aliases\"), dict):\n",
        "            for lang, arr in obj[\"aliases\"].items():\n",
        "                if isinstance(arr, list):\n",
        "                    aliases_by_style_lang[style][lang].extend(arr)\n",
        "        if isinstance(obj.get(\"negatives\"), list):\n",
        "            negatives_by_style[style].extend(obj[\"negatives\"])\n",
        "        if isinstance(obj.get(\"regex\"), list):\n",
        "            regex_by_style[style].extend(obj[\"regex\"])\n",
        "\n",
        "    for style, obj in aliases_en.items():\n",
        "        if isinstance(obj.get(\"aliases\"), dict) and isinstance(obj[\"aliases\"].get(\"en\"), list):\n",
        "            aliases_by_style_lang[style][\"en\"].extend(obj[\"aliases\"][\"en\"])\n",
        "\n",
        "    for style, obj in aliases_ml.items():\n",
        "        if isinstance(obj.get(\"aliases\"), dict):\n",
        "            for lang, arr in obj[\"aliases\"].items():\n",
        "                if isinstance(arr, list):\n",
        "                    aliases_by_style_lang[style][lang].extend(arr)\n",
        "\n",
        "    for style in list(aliases_by_style_lang.keys()):\n",
        "        for lang in list(aliases_by_style_lang[style].keys()):\n",
        "            cleaned = []\n",
        "            seen = set()\n",
        "            for a in aliases_by_style_lang[style][lang]:\n",
        "                a2 = norm_text(a).lower()\n",
        "                if not a2 or a2 in seen or len(a2) < 3 or a2 in {\"style\", \"wear\", \"look\", \"fashion\"}:\n",
        "                    continue\n",
        "                seen.add(a2)\n",
        "                cleaned.append(a2)\n",
        "            aliases_by_style_lang[style][lang] = cleaned\n",
        "\n",
        "    for style, negs in negatives_by_style.items():\n",
        "        cleaned = []\n",
        "        seen = set()\n",
        "        for n in negs:\n",
        "            n2 = norm_text(n).lower()\n",
        "            if n2 and n2 not in seen:\n",
        "                seen.add(n2)\n",
        "                cleaned.append(n2)\n",
        "        negatives_by_style[style] = cleaned\n",
        "\n",
        "    for style, regs in regex_by_style.items():\n",
        "        cleaned = []\n",
        "        seen = set()\n",
        "        for r in regs:\n",
        "            if r not in seen:\n",
        "                seen.add(r)\n",
        "                cleaned.append(r)\n",
        "        regex_by_style[style] = cleaned\n",
        "\n",
        "    return aliases_by_style_lang, negatives_by_style, regex_by_style\n",
        "\n",
        "def build_prompts_for_style(style: str, lang_aliases: Dict, max_per_lang: int=12) -> List[str]:\n",
        "    \"\"\"Build embedding prompts for each style.\"\"\"\n",
        "    prompts = []\n",
        "    en_aliases = lang_aliases.get(\"en\", [])[:max_per_lang]\n",
        "    if en_aliases:\n",
        "        prompts.append(f\"{style} style: \" + \", \".join(en_aliases))\n",
        "\n",
        "    other_terms = []\n",
        "    for lang, arr in lang_aliases.items():\n",
        "        if lang != \"en\":\n",
        "            other_terms.extend(arr[:max_per_lang])\n",
        "\n",
        "    if other_terms:\n",
        "        chunk_size = 15\n",
        "        for i in range(0, len(other_terms), chunk_size):\n",
        "            seg = other_terms[i:i+chunk_size]\n",
        "            prompts.append(f\"{style} style: \" + \", \".join(seg))\n",
        "    return prompts\n",
        "\n",
        "def safe_compile_regex_list(regex_list: List[str]) -> List:\n",
        "    \"\"\"Compile regex list safely.\"\"\"\n",
        "    compiled = []\n",
        "    for pat in regex_list or []:\n",
        "        try:\n",
        "            compiled.append(re.compile(pat, re.IGNORECASE))\n",
        "        except Exception:\n",
        "            continue\n",
        "    return compiled\n",
        "\n",
        "def contains_any(text: str, terms: List[str]) -> bool:\n",
        "    \"\"\"Check if text contains any term.\"\"\"\n",
        "    text_lower = text.lower()\n",
        "    return any(term in text_lower for term in terms)\n",
        "\n",
        "def predict_styles(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Predict fashion style using sentence embeddings and rules.\"\"\"\n",
        "    print(\"\\n🎨 Starting Style Prediction...\")\n",
        "\n",
        "    if not os.path.exists(SEED_FILE_PATH):\n",
        "        print(\"⚠️ Warning: aliases_seed_en.json not found - skipping style prediction\")\n",
        "        df[\"pred_style\"] = \"\"\n",
        "        df[\"pred_conf\"] = 0.0\n",
        "        return df\n",
        "\n",
        "    if not os.path.exists(ALIASES_ML_PATH):\n",
        "        print(\"🌐 Generating multilingual aliases...\")\n",
        "        build_multilang_aliases()\n",
        "\n",
        "    if not os.path.exists(STYLE_TO_GLAMI_PATH):\n",
        "        print(\"🔧 Generating style mappings...\")\n",
        "        build_style_to_glami_names()\n",
        "\n",
        "    # Load models and data\n",
        "    print(\"📥 Loading style data...\")\n",
        "    style_to_glami = load_json(STYLE_TO_GLAMI_PATH)\n",
        "    aliases_en = load_json(SEED_FILE_PATH)\n",
        "    aliases_ml = load_json(ALIASES_ML_PATH)\n",
        "\n",
        "    aliases_by_style_lang, negatives_by_style, regex_by_style = merge_aliases(\n",
        "        style_to_glami, aliases_en, aliases_ml\n",
        "    )\n",
        "    styles = sorted(aliases_by_style_lang.keys())\n",
        "    print(f\"✓ Found {len(styles)} style categories\")\n",
        "\n",
        "    # 在这里定义 style_prompts\n",
        "    style_prompts = {}\n",
        "    for s in styles:\n",
        "        ps = build_prompts_for_style(s, aliases_by_style_lang[s])\n",
        "        style_prompts[s] = ps if ps else [f\"{s} style\"]\n",
        "\n",
        "    # Load encoder\n",
        "    print(f\"🤖 Loading style encoder: {STYLE_MODEL_NAME}\")\n",
        "    encoder = SentenceTransformer(STYLE_MODEL_NAME)\n",
        "    if torch.cuda.is_available():\n",
        "        encoder = encoder.to(DEVICE)\n",
        "    print(\"✓ Encoder loaded\")\n",
        "\n",
        "    def embed_text(lines: List[str]) -> np.ndarray:\n",
        "        vectors = encoder.encode(\n",
        "            lines, batch_size=STYLE_BATCH_SIZE, show_progress_bar=False,\n",
        "            normalize_embeddings=True, device=DEVICE\n",
        "        )\n",
        "        return np.asarray(vectors)\n",
        "\n",
        "    # Build style prototypes\n",
        "    print(\"🔨 Building style prototypes...\")\n",
        "    prototype_matrix = []\n",
        "    for s in tqdm(styles, desc=\"Creating prototypes\"):\n",
        "        vecs = embed_text(style_prompts[s])\n",
        "        prototype = vecs.mean(axis=0)\n",
        "        prototype_matrix.append(prototype)\n",
        "    prototype_matrix = normalize(np.vstack(prototype_matrix))\n",
        "    print(f\"✓ Prototypes created for {len(styles)} styles\")\n",
        "\n",
        "    compiled_regex = {s: safe_compile_regex_list(regex_by_style.get(s, [])) for s in styles} if STYLE_RULE_BOOST else {}\n",
        "\n",
        "    valid_cols = [c for c in STYLE_TEXT_COLS if c in df.columns]\n",
        "    if valid_cols:\n",
        "        df[\"_text\"] = df[valid_cols].fillna(\"\").astype(str).agg(\" [SEP] \".join, axis=1)\n",
        "    else:\n",
        "        print(\"⚠️ Warning: No valid text columns found for style prediction\")\n",
        "        df[\"pred_style\"] = \"\"\n",
        "        df[\"pred_conf\"] = 0.0\n",
        "        return df\n",
        "\n",
        "    # Batch embedding\n",
        "    texts = df[\"_text\"].tolist()\n",
        "    sim_matrix = []\n",
        "\n",
        "    num_batches = len(range(0, len(texts), STYLE_BATCH_SIZE))\n",
        "    print(f\"🔍 Processing {len(texts):,} items in {num_batches} batches...\")\n",
        "    time_estimator = TimeEstimator(num_batches)\n",
        "\n",
        "    for i, batch_start in enumerate(range(0, len(texts), STYLE_BATCH_SIZE)):\n",
        "        batch_texts = texts[batch_start:batch_start + STYLE_BATCH_SIZE]\n",
        "        text_vecs = embed_text(batch_texts)\n",
        "        sim = text_vecs @ prototype_matrix.T\n",
        "        sim_matrix.append(sim)\n",
        "\n",
        "        # Update progress\n",
        "        if i % 10 == 0 or i == num_batches - 1:\n",
        "            stats = time_estimator.update(i + 1)\n",
        "            if stats:\n",
        "                print(f\"\\r📊 Progress: {stats['progress']} ({stats['percent']}) | \"\n",
        "                      f\"Elapsed: {stats['elapsed']} | ETA: {stats['eta']}\", end=\"\")\n",
        "\n",
        "    print(\"\\n✓ Embeddings completed\")\n",
        "    sim_matrix = np.vstack(sim_matrix)\n",
        "\n",
        "    print(\"⚙️ Applying rules and penalties...\")\n",
        "    lowered_text = df[\"_text\"].str.lower().fillna(\"\")\n",
        "\n",
        "\n",
        "    if STYLE_USE_NEGATIVES or STYLE_RULE_BOOST:\n",
        "        for idx, style in enumerate(tqdm(styles, desc=\"Processing styles\", ncols=80)):\n",
        "            if STYLE_USE_NEGATIVES and negatives_by_style.get(style):\n",
        "                neg_terms = negatives_by_style[style]\n",
        "                if neg_terms:\n",
        "                    mask = lowered_text.apply(lambda t: any(term in t for term in neg_terms))\n",
        "                    if mask.any():\n",
        "                        sim_matrix[mask.values, idx] = np.maximum(\n",
        "                            sim_matrix[mask.values, idx] - STYLE_NEG_PENALTY_VALUE, -1.0\n",
        "                        )\n",
        "\n",
        "            if STYLE_RULE_BOOST and compiled_regex.get(style):\n",
        "                regs = compiled_regex[style]\n",
        "                if regs:\n",
        "                    mask = lowered_text.apply(lambda t: any(r.search(t) for r in regs))\n",
        "                    if mask.any():\n",
        "                        sim_matrix[mask.values, idx] = np.minimum(\n",
        "                            sim_matrix[mask.values, idx] + STYLE_RULE_BOOST_VALUE, 1.0\n",
        "                        )\n",
        "\n",
        "    print(\"✓ Rules and penalties applied\")\n",
        "\n",
        "\n",
        "    print(\"📊 Finalizing predictions...\")\n",
        "    best_indices = sim_matrix.argmax(axis=1)\n",
        "    df[\"pred_style\"] = [styles[i] for i in best_indices]\n",
        "    df[\"pred_conf\"] = sim_matrix.max(axis=1).astype(float)\n",
        "    df.drop(columns=[\"_text\"], inplace=True, errors=\"ignore\")\n",
        "\n",
        "\n",
        "    style_counts = df[\"pred_style\"].value_counts()\n",
        "    print(f\"\\n✓ Style prediction completed for {len(df):,} items\")\n",
        "    print(f\"📊 Top 5 styles: {', '.join([f'{k}({v:,})' for k, v in style_counts.head(5).items()])}\")\n",
        "    print(f\"📊 Average confidence: {df['pred_conf'].mean():.3f}\\n\")\n",
        "\n",
        "    return df"
      ]
    },
