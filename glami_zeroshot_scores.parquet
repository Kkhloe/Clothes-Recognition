      "source": [
        "# ====================== 5. Color Extraction ======================\n",
        "color_map = {\n",
        "    \"black\": [\"black\", \"černá\", \"cerná\", \"černé\", \"cerne\", \"černý\", \"cerny\", \"čierna\", \"cierna\", \"čierne\", \"cierne\", \"čierny\", \"cierny\", \"μαύρο\", \"μαυρο\", \"μαύρη\", \"μαυρη\", \"fekete\", \"črna\", \"crna\", \"juoda\", \"melns\", \"черен\", \"must\", \"siyah\", \"negru\", \"negro\"],\n",
        "    \"white\": [\"white\", \"bílá\", \"bila\", \"bílé\", \"bile\", \"bílý\", \"bily\", \"biela\", \"biele\", \"biely\", \"λευκό\", \"λευκο\", \"λευκή\", \"λευκη\", \"fehér\", \"feher\", \"bela\", \"bijela\", \"balta\", \"balts\", \"бял\", \"valge\", \"beyaz\", \"alb\", \"blanco\"],\n",
        "    \"gray\": [\"gray\", \"grey\", \"šedá\", \"seda\", \"šedé\", \"sede\", \"šedý\", \"sedy\", \"sivá\", \"siva\", \"sivé\", \"sive\", \"sivý\", \"sivy\", \"γκρι\", \"szürke\", \"szurke\", \"siva\", \"pilka\", \"pelēks\", \"peleks\", \"сив\", \"hall\", \"gri\", \"gris\"],\n",
        "    \"blue\": [\"blue\", \"modrá\", \"modre\", \"modré\", \"modrý\", \"modry\", \"modrá\", \"modry\", \"μπλε\", \"γαλάζιο\", \"γαλαζιο\", \"kék\", \"kek\", \"modra\", \"plava\", \"mėlyna\", \"melyna\", \"zils\", \"син\", \"sinine\", \"mavi\", \"albastru\", \"azul\", \"navy\", \"indigo\"],\n",
        "    \"red\": [\"red\", \"červená\", \"cervena\", \"červené\", \"cervene\", \"červený\", \"cerveny\", \"červená\", \"cervena\", \"κόκκινο\", \"κοκκινο\", \"κόκκινη\", \"κοκκινη\", \"piros\", \"rdeča\", \"rdeca\", \"crvena\", \"raudona\", \"sarkans\", \"червен\", \"punane\", \"kırmızı\", \"kirmizi\", \"roșu\", \"rosu\", \"rojo\", \"bordó\", \"vínová\", \"vinova\"],\n",
        "    \"green\": [\"green\", \"zelená\", \"zelena\", \"zelené\", \"zelene\", \"zelený\", \"zeleny\", \"zelená\", \"zeleny\", \"πράσινο\", \"πρασινο\", \"zöld\", \"zold\", \"zelena\", \"žalia\", \"zalia\", \"zaļš\", \"zalš\", \"зелен\", \"roheline\", \"yeşil\", \"yesil\", \"verde\", \"khaki\"],\n",
        "    \"yellow\": [\"yellow\", \"žlutá\", \"zluta\", \"žluté\", \"zlute\", \"žlutý\", \"zluty\", \"žltá\", \"zlta\", \"žlté\", \"zlte\", \"κίτρινο\", \"κιτρινο\", \"sárga\", \"sarga\", \"rumena\", \"žuta\", \"geltona\", \"dzeltens\", \"жълт\", \"kollane\", \"sarı\", \"sari\", \"galben\", \"amarillo\", \"mustard\"],\n",
        "    \"pink\": [\"pink\", \"růžová\", \"ruzova\", \"růžové\", \"ruzove\", \"ružová\", \"ruzova\", \"ροζ\", \"rózsaszín\", \"rozsaszin\", \"roza\", \"ružičasta\", \"rožinė\", \"rozine\", \"rozā\", \"розов\", \"roosa\", \"pembe\", \"roz\", \"rosa\", \"fuchsiová\", \"fuchsiove\"],\n",
        "    \"purple\": [\"purple\", \"violet\", \"fialová\", \"fialove\", \"fialova\", \"μωβ\", \"lila\", \"lilac\", \"lila\", \"vijolična\", \"ljubičasta\", \"violetinė\", \"violetine\", \"violeta\", \"лилав\", \"lilla\", \"mor\", \"mov\", \"morado\", \"púrpura\", \"purpura\"],\n",
        "    \"brown\": [\"brown\", \"hnědá\", \"hneda\", \"hnědé\", \"hnede\", \"hnedá\", \"hneda\", \"καφέ\", \"καφε\", \"barna\", \"rjava\", \"smeđa\", \"smeda\", \"ruda\", \"brūns\", \"bruns\", \"кафяв\", \"pruun\", \"kahverengi\", \"maro\", \"marrón\", \"marron\", \"café\", \"cafe\", \"čokoládová\", \"chocolate\"],\n",
        "    \"beige\": [\"beige\", \"béžová\", \"bezova\", \"béžové\", \"bezove\", \"béžová\", \"bezova\", \"μπεζ\", \"bézs\", \"bezs\", \"bež\", \"smėlio\", \"smelio\", \"bēšs\", \"bess\", \"бежов\", \"beež\", \"beez\", \"bej\", \"beige\", \"nude\", \"mocca\"],\n",
        "    \"orange\": [\"orange\", \"oranžová\", \"oranzova\", \"oranžová\", \"oranzova\", \"πορτοκαλί\", \"πορτοκαλι\", \"narancs\", \"oranžna\", \"narančasta\", \"oranzine\", \"oranžs\", \"оранжев\", \"oranž\", \"oranz\", \"turuncu\", \"portocaliu\", \"naranja\", \"korálová\", \"koralova\"],\n",
        "    \"gold\": [\"gold\", \"zlatá\", \"zlata\", \"zlaté\", \"zlate\", \"zlatá\", \"zlata\", \"χρυσό\", \"χρυσο\", \"arany\", \"zlata\", \"zlatna\", \"auksinė\", \"auksine\", \"zelta\", \"златен\", \"kuldne\", \"altın\", \"altin\", \"auriu\", \"dorado\"],\n",
        "    \"silver\": [\"silver\", \"stříbrná\", \"stribrna\", \"stříbrné\", \"stribrne\", \"strieborná\", \"strieborna\", \"ασημί\", \"ασημι\", \"ezüst\", \"ezust\", \"srebrna\", \"sidabrinė\", \"sidabrine\", \"sudraba\", \"сребърен\", \"hõbedane\", \"hobedane\", \"gümüş\", \"gumus\", \"argintiu\", \"plateado\"]\n",
        "}\n",
        "\n",
        "variant_to_canonical = {}\n",
        "for canonical, variants in color_map.items():\n",
        "    for v in variants:\n",
        "        variant_to_canonical[v.lower()] = canonical\n",
        "\n",
        "geo_terms = {\n",
        "    \"en\": [\"black\", \"white\", \"gray\", \"grey\", \"blue\", \"red\", \"green\", \"yellow\", \"pink\", \"purple\", \"violet\", \"brown\", \"beige\", \"orange\", \"gold\", \"silver\", \"navy\", \"indigo\", \"khaki\", \"nude\", \"mustard\", \"lilac\", \"chocolate\"],\n",
        "    \"cz\": [\"černá\", \"cerná\", \"černé\", \"cerne\", \"černý\", \"cerny\", \"bílá\", \"bila\", \"bílé\", \"bile\", \"bílý\", \"bily\", \"šedá\", \"seda\", \"šedé\", \"sede\", \"šedý\", \"sedy\", \"modrá\", \"modre\", \"modré\", \"modrý\", \"modry\", \"červená\", \"cervena\", \"červené\", \"cervene\", \"červený\", \"cerveny\", \"zelená\", \"zelena\", \"zelené\", \"zelene\", \"zelený\", \"zeleny\", \"žlutá\", \"zluta\", \"žluté\", \"zlute\", \"žlutý\", \"zluty\", \"růžová\", \"ruzova\", \"růžové\", \"ruzove\", \"fialová\", \"fialove\", \"hnědá\", \"hneda\", \"hnědé\", \"hnede\", \"béžová\", \"bezova\", \"béžové\", \"bezove\", \"oranžová\", \"oranzova\", \"zlatá\", \"zlata\", \"zlaté\", \"zlate\", \"stříbrná\", \"stribrna\", \"stříbrné\", \"stribrne\"],\n",
        "    \"sk\": [\"čierna\", \"cierna\", \"čierne\", \"cierne\", \"čierny\", \"cierny\", \"biela\", \"biele\", \"biely\", \"sivá\", \"siva\", \"sivé\", \"sive\", \"sivý\", \"sivy\", \"modrá\", \"modry\", \"červená\", \"cervena\", \"zelená\", \"zeleny\", \"žltá\", \"zlta\", \"žlté\", \"zlte\", \"ružová\", \"ruzova\", \"fialova\", \"hnedá\", \"hneda\", \"béžová\", \"bezova\", \"oranžová\", \"oranzova\", \"zlatá\", \"zlata\", \"strieborná\", \"strieborna\"],\n",
        "    \"gr\": [\"μαύρο\", \"μαυρο\", \"μαύρη\", \"μαυρη\", \"λευκό\", \"λευκο\", \"λευκή\", \"λευκη\", \"γκρι\", \"μπλε\", \"γαλάζιο\", \"γαλαζιο\", \"κόκκινο\", \"κοκκινο\", \"κόκκινη\", \"κοκκινη\", \"πράσινο\", \"πρασινο\", \"κίτρινο\", \"κιτρινο\", \"ροζ\", \"μωβ\", \"καφέ\", \"καφε\", \"μπεζ\", \"πορτοκαλί\", \"πορτοκαλι\", \"χρυσό\", \"χρυσο\", \"ασημί\", \"ασημι\"],\n",
        "    \"hu\": [\"fekete\", \"fehér\", \"feher\", \"szürke\", \"szurke\", \"kék\", \"kek\", \"piros\", \"zöld\", \"zold\", \"sárga\", \"sarga\", \"rózsaszín\", \"rozsaszin\", \"lila\", \"barna\", \"bézs\", \"bezs\", \"narancs\", \"arany\", \"ezüst\", \"ezust\"],\n",
        "    \"si\": [\"črna\", \"bela\", \"siva\", \"modra\", \"rdeča\", \"rdeca\", \"zelena\", \"rumena\", \"roza\", \"vijolična\", \"rjava\", \"bež\", \"oranžna\", \"zlata\", \"srebrna\"],\n",
        "    \"lt\": [\"juoda\", \"balta\", \"pilka\", \"mėlyna\", \"melyna\", \"raudona\", \"žalia\", \"zalia\", \"geltona\", \"rožinė\", \"rozine\", \"violetinė\", \"violetine\", \"ruda\", \"smėlio\", \"smelio\", \"oranzine\", \"auksinė\", \"auksine\", \"sidabrinė\", \"sidabrine\"],\n",
        "    \"lv\": [\"melns\", \"balts\", \"pelēks\", \"peleks\", \"zils\", \"sarkans\", \"zaļš\", \"zalš\", \"dzeltens\", \"rozā\", \"violeta\", \"brūns\", \"bruns\", \"bēšs\", \"bess\", \"oranžs\", \"zelta\", \"sudraba\"],\n",
        "    \"hr\": [\"crna\", \"bijela\", \"siva\", \"plava\", \"crvena\", \"zelena\", \"žuta\", \"ruzicasta\", \"ružičasta\", \"ljubičasta\", \"smeđa\", \"smeda\", \"bež\", \"narančasta\", \"zlatna\", \"srebrna\"],\n",
        "    \"bg\": [\"черен\", \"бял\", \"сив\", \"син\", \"червен\", \"зелен\", \"жълт\", \"розов\", \"лилав\", \"кафяв\", \"бежов\", \"оранжев\", \"златен\", \"сребърен\"],\n",
        "    \"ee\": [\"must\", \"valge\", \"hall\", \"sinine\", \"punane\", \"roheline\", \"kollane\", \"roosa\", \"lilla\", \"pruun\", \"beež\", \"beez\", \"oranž\", \"oranz\", \"kuldne\", \"hõbedane\", \"hobedane\"],\n",
        "    \"tr\": [\"siyah\", \"beyaz\", \"gri\", \"mavi\", \"kırmızı\", \"kirmizi\", \"yeşil\", \"yesil\", \"sarı\", \"sari\", \"pembe\", \"mor\", \"kahverengi\", \"bej\", \"turuncu\", \"altın\", \"altin\", \"gümüş\", \"gumus\"],\n",
        "    \"ro\": [\"negru\", \"alb\", \"gri\", \"albastru\", \"roșu\", \"rosu\", \"verde\", \"galben\", \"roz\", \"mov\", \"maro\", \"beige\", \"portocaliu\", \"auriu\", \"argintiu\"],\n",
        "    \"es\": [\"negro\", \"blanco\", \"gris\", \"azul\", \"rojo\", \"verde\", \"amarillo\", \"rosa\", \"morado\", \"púrpura\", \"purpura\", \"marrón\", \"marron\", \"café\", \"cafe\", \"beige\", \"naranja\", \"dorado\", \"plateado\"]\n",
        "}\n",
        "\n",
        "valid_terms = set(variant_to_canonical.keys())\n",
        "geo_candidates = {}\n",
        "geo_patterns = {}\n",
        "\n",
        "for geo, terms in geo_terms.items():\n",
        "    merged = sorted(set([t.lower() for t in (geo_terms.get(\"en\", []) + terms) if t.lower() in valid_terms]))\n",
        "    geo_candidates[geo] = merged\n",
        "    escaped = sorted([re.escape(t) for t in merged], key=len, reverse=True)\n",
        "    geo_patterns[geo] = re.compile(r\"(?<!\\\\w)(\" + \"|\".join(escaped) + r\")(?!\\\\w)\") if escaped else None\n",
        "\n",
        "kw_model = KeyBERT(model=STYLE_MODEL_NAME)\n",
        "\n",
        "def normalize_geo(g):\n",
        "    \"\"\"Normalize geo code.\"\"\"\n",
        "    key = str(g).strip().lower()\n",
        "    return key if key in geo_candidates else \"en\"\n",
        "\n",
        "def extract_direct_scores(text, geo):\n",
        "    \"\"\"Extract colors via direct keyword matching.\"\"\"\n",
        "    scores = {}\n",
        "    pattern = geo_patterns.get(geo)\n",
        "    if pattern:\n",
        "        for match in pattern.finditer(text):\n",
        "            color = variant_to_canonical.get(match.group(1).lower())\n",
        "            if color:\n",
        "                scores[color] = 1.0\n",
        "    return scores\n",
        "\n",
        "def to_result(score_by_color):\n",
        "    \"\"\"Convert color scores to final result format.\"\"\"\n",
        "    ordered = sorted(score_by_color.items(), key=lambda x: x[1], reverse=True)\n",
        "    all_colors = [c for c, _ in ordered]\n",
        "    high_conf = [c for c, s in ordered if s >= COLOR_SCORE_THRESHOLD]\n",
        "    primary_high = high_conf[0] if high_conf else \"\"\n",
        "    return all_colors, high_conf, score_by_color, primary_high\n",
        "\n",
        "def extract_colors_with_conf(text, geo, top_n=8):\n",
        "    \"\"\"Extract colors with confidence scores - fixed version.\"\"\"\n",
        "    if not text or not text.strip():\n",
        "        return [], [], {}, \"\"\n",
        "\n",
        "    geo_norm = normalize_geo(geo)\n",
        "\n",
        "    direct_scores = extract_direct_scores(text, geo_norm)\n",
        "    if direct_scores:\n",
        "        return to_result(direct_scores)\n",
        "\n",
        "    try:\n",
        "        candidates = geo_candidates.get(geo_norm, geo_candidates.get(\"en\", []))\n",
        "        text_lower = text.lower()\n",
        "\n",
        "        scores = {}\n",
        "        for color_term in candidates:\n",
        "            if color_term in text_lower:\n",
        "                color = variant_to_canonical.get(color_term)\n",
        "                if color:\n",
        "                    scores[color] = max(scores.get(color, 0.0), 0.8)\n",
        "\n",
        "        if scores:\n",
        "            return to_result(scores)\n",
        "\n",
        "        try:\n",
        "            model = get_keybert_model()\n",
        "            if model:\n",
        "                keywords = model.extract_keywords(\n",
        "                    text,\n",
        "                    candidates=candidates,\n",
        "                    keyphrase_ngram_range=(1, 1),  #\n",
        "                    stop_words=None,\n",
        "                    top_n=min(top_n, len(candidates))\n",
        "                )\n",
        "\n",
        "                for term, score in keywords:\n",
        "                    color = variant_to_canonical.get(term.lower().strip())\n",
        "                    if color:\n",
        "                        scores[color] = max(scores.get(color, 0.0), float(score))\n",
        "        except Exception as e:\n",
        "            pass\n",
        "\n",
        "        return to_result(scores)\n",
        "\n",
        "    except Exception as e:\n",
        "        return [], [], {}, \"\"\n",
        "\n",
        "def extract_colors(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Extract primary and high-confidence colors using final_input_text.\"\"\"\n",
        "    print(\"\\n🎨 Starting Color Extraction...\")\n",
        "\n",
        "    if \"final_input_text\" not in df.columns:\n",
        "        if \"clean_name\" in df.columns and \"clean_desc\" in df.columns:\n",
        "            df[\"final_input_text\"] = (df[\"clean_name\"].fillna(\"\") + \" \" +\n",
        "                                      df[\"clean_desc\"].fillna(\"\")).str.strip()\n",
        "        else:\n",
        "            raise KeyError(\"final_input_text column is required for color extraction\")\n",
        "\n",
        "    df[\"text_input\"] = df[\"final_input_text\"].fillna(\"\").astype(str)\n",
        "    df[\"geo\"] = df.get(\"geo\", \"en\")\n",
        "    df[\"geo_norm\"] = df[\"geo\"].map(normalize_geo)\n",
        "\n",
        "    unique_texts = df[\"text_input\"].unique()\n",
        "    print(f\"🔍 Processing {len(unique_texts):,} unique text items...\")\n",
        "\n",
        "    cache = {}\n",
        "\n",
        "    import warnings\n",
        "    warnings.filterwarnings('ignore')\n",
        "\n",
        "    for text in tqdm(unique_texts, desc=\"Extracting colors\", unit=\"items\"):\n",
        "        sample_geo = df[df[\"text_input\"] == text][\"geo_norm\"].iloc[0]\n",
        "        cache[text] = extract_colors_with_conf(text, sample_geo)\n",
        "\n",
        "    results = df[\"text_input\"].map(cache)\n",
        "\n",
        "    df[\"colors\"] = results.map(lambda x: x[0] if x else [])\n",
        "    df[\"colors_highconf\"] = results.map(lambda x: x[1] if x else [])\n",
        "    df[\"primary_color\"] = df[\"colors\"].map(lambda x: x[0] if len(x) > 0 else \"\")\n",
        "    df[\"primary_color_highconf\"] = results.map(lambda x: x[3] if x else \"\")\n",
        "    df[\"colors_str\"] = df[\"colors\"].map(lambda x: \"|\".join(x) if x else \"\")\n",
        "    df[\"colors_highconf_str\"] = df[\"colors_highconf\"].map(lambda x: \"|\".join(x) if x else \"\")\n",
        "\n",
        "    df.drop(columns=[\"text_input\", \"geo_norm\"], inplace=True, errors=\"ignore\")\n",
        "\n",
        "    colors_found = (df[\"primary_color\"] != \"\").sum()\n",
        "    print(f\"✓ Found primary colors for {colors_found:,}/{len(df):,} items\")\n",
        "    print(f\"✓ Color extraction completed\\n\")\n",
        "\n",
        "    return df"
      ]
    },
