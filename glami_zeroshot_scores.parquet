      "source": [
        "# ====================== 6. Visual Pattern Extraction ======================\n",
        "pattern_map = {\n",
        "    \"striped\": [\n",
        "        \"striped\", \"pruhovaný\", \"pruhovaný\", \"ριγέ\", \"csikos\", \"prugast\",\n",
        "        \"danginė\", \"svītriņuots\", \"prugast\", \"ивист\", \"riiul\",\n",
        "        \"çizgili\", \"dungat\", \"rayado\"\n",
        "    ],\n",
        "    \"floral\": [\n",
        "        \"floral\", \"květný\", \"květný\", \"λουλουδάτο\", \"virágos\", \"cvetličast\",\n",
        "        \"gėlėtas\", \"zaļģurīgs\", \"cvetni\", \"цветен\", \"lilleline\",\n",
        "        \"çiçekli\", \"floral\", \"floral\"\n",
        "    ],\n",
        "    \"plaid\": [\n",
        "        \"plaid\", \"karo\", \"karo\", \"καρό\", \"kari\", \"kockast\",\n",
        "        \"languotas\", \"ķieģeļveida\", \"kockast\", \"клетчат\", \"ruuduline\",\n",
        "        \"ekose\", \"carou\", \"cuadros\"\n",
        "    ],\n",
        "    \"polka_dot\": [\n",
        "        \"polka dot\", \"tečkovaný\", \"tečkovaný\", \"πουά\", \"pöttyös\", \"pikto\",\n",
        "        \"taškėtas\", \"punktīts\", \"pikto\", \"точкист\", \"punktidega\",\n",
        "        \"benekli\", \"punctat\", \"lunares\"\n",
        "    ],\n",
        "    \"animal_print\": [\n",
        "        \"animal print\", \"zvířecí tisk\", \"zvierací tisk\", \"ζωικό σχέδιο\",\n",
        "        \"állatnyomtatás\", \"živalski tisk\", \"gyvūnijų spaudas\",\n",
        "        \"dzīvnieku druka\", \"životinjski print\", \"животински принт\",\n",
        "        \"loomselöög\", \"hayvan baskı\", \"animal print\", \"estampado animal\"\n",
        "    ],\n",
        "    \"camouflage\": [\n",
        "        \"camouflage\", \"kamufláž\", \"kamufláž\", \"καμουφλάζ\",\n",
        "        \"kamuflázs\", \"kamuflaža\", \"kamufližas\", \"kamufliža\",\n",
        "        \"kamuflaža\", \"камуфлаж\", \"kamuflee\", \"kamuflaj\",\n",
        "        \"camuflaj\", \"camuflaje\"\n",
        "    ],\n",
        "    \"geometric\": [\n",
        "        \"geometric\", \"geometrický\", \"geometrický\", \"γεωμετρικό\",\n",
        "        \"geometriai\", \"geometrijski\", \"geometrinis\", \"ģeometrisks\",\n",
        "        \"geometrijski\", \"геометричен\", \"geomeetriline\", \"geometrik\",\n",
        "        \"geometric\", \"geométrico\"\n",
        "    ],\n",
        "    \"paisley\": [\n",
        "        \"paisley\", \"paisley\", \"paisley\", \"πέισλι\",\n",
        "        \"paisley\", \"paisley\", \"peizlija\", \"peizlija\",\n",
        "        \"paisley\", \"пајсли\", \"peisli\", \"paisley\",\n",
        "        \"paisley\", \"paisley\"\n",
        "    ],\n",
        "    \"tie_dye\": [\n",
        "        \"tie dye\", \"batik\", \"batik\", \"μπατίκ\",\n",
        "        \"batik\", \"batik\", \"batikas\", \"batiks\",\n",
        "        \"batik\", \"батик\", \"batik\", \"batik\",\n",
        "        \"batik\", \"batik\"\n",
        "    ],\n",
        "    \"logo\": [\n",
        "        \"logo\", \"logo\", \"logo\", \"λόγο\",\n",
        "        \"logo\", \"logo\", \"logo\", \"logo\",\n",
        "        \"logo\", \"лого\", \"logo\", \"logo\",\n",
        "        \"logo\", \"logo\"\n",
        "    ],\n",
        "    \"lace\": [\n",
        "        \"lace\", \"krajka\", \"krajka\", \"δαντέλα\",\n",
        "        \"csipke\", \"čipka\", \"madalas\", \"madalas\",\n",
        "        \"čipka\", \"чупка\", \"kell\", \"dantel\",\n",
        "        \"dantelă\", \"encaje\"\n",
        "    ],\n",
        "    \"embroidered\": [\n",
        "        \"embroidered\", \"výšívaný\", \"výšívaný\", \"κεντημένο\",\n",
        "        \"készített\", \"vezen\", \"išsiuvytas\", \"izšuvots\",\n",
        "        \"vezen\", \"вишит\", \"kendeline\", \"nakışlı\",\n",
        "        \"brodat\", \"bordado\"\n",
        "    ],\n",
        "    \"jacquard\": [\n",
        "        \"jacquard\", \"žakár\", \"žakár\", \"ζακάρ\",\n",
        "        \"dzakár\", \"žakar\", \"žakardas\", \"žakards\",\n",
        "        \"žakar\", \"жақар\", \"žakard\", \"jakarlı\",\n",
        "        \"jacquard\", \"jacquard\"\n",
        "    ],\n",
        "    \"ribbed\": [\n",
        "        \"ribbed\", \"žebrovaný\", \"žebrovaný\", \"ρεζιέρα\",\n",
        "        \"bordás\", \"rebrast\", \"briaunėtas\", \"ribots\",\n",
        "        \"rebrast\", \"ребрист\", \"ribine\", \"fitilli\",\n",
        "        \"ribat\", \"canalé\"\n",
        "    ],\n",
        "    \"quilted\": [\n",
        "        \"quilted\", \"prošívaný\", \"prošívaný\", \"καπιτονέ\",\n",
        "        \"középenztárt\", \"prošiven\", \"prosiuvytas\", \"prošivots\",\n",
        "        \"prošiven\", \"прошиван\", \"polsterdat\", \"kapitone\",\n",
        "        \"quiltat\", \"acolchado\"\n",
        "    ],\n",
        "    \"mesh\": [\n",
        "        \"mesh\", \"síťový\", \"sietový\", \"λέσχημα\",\n",
        "        \"hálós\", \"mrežast\", \"tinklelis\", \"tīklains\",\n",
        "        \"mrežast\", \"мрежест\", \"võrviline\", \"ağ\",\n",
        "        \"plasă\", \"rejilla\"\n",
        "    ],\n",
        "    \"solid\": [\n",
        "        \"solid\", \"jednobarevný\", \"jednofarebný\", \"μονόχρωμο\",\n",
        "        \"egyszínű\", \"enobaren\", \"vienospalvis\", \"vienkrāsains\",\n",
        "        \"jednobojan\", \"монохромен\", \"ühtvärviline\", \"tek\",\n",
        "        \"solid\", \"sólido\"\n",
        "    ]\n",
        "}\n",
        "\n",
        "variant_to_pattern = {}\n",
        "for canonical, variants in pattern_map.items():\n",
        "    for v in variants:\n",
        "        variant_to_pattern[v.lower()] = canonical\n",
        "\n",
        "candidate_terms = sorted(set(variant_to_pattern.keys()))\n",
        "pattern_regex = re.compile(r\"(?<!\\\\w)(\" + \"|\".join(sorted([re.escape(x) for x in candidate_terms], key=len, reverse=True)) + r\")(?!\\\\w)\")\n",
        "\n",
        "query_bank = [\n",
        "    \"stripe pattern\", \"floral print\", \"plaid check\", \"polka dot\", \"animal print\", \"camouflage\",\n",
        "    \"geometric motif\", \"paisley pattern\", \"tie dye\", \"logo print\", \"lace detail\", \"embroidered detail\",\n",
        "    \"jacquard texture\", \"ribbed texture\", \"quilted texture\", \"mesh texture\", \"solid plain\"\n",
        "]\n",
        "\n",
        "mbert_name = \"bert-base-multilingual-cased\"\n",
        "mbert_tok = AutoTokenizer.from_pretrained(mbert_name, use_fast=True)\n",
        "mbert_model = AutoModel.from_pretrained(mbert_name)\n",
        "mbert_model.eval()\n",
        "\n",
        "def normalize_vec(x):\n",
        "    \"\"\"Vector normalization.\"\"\"\n",
        "    x = np.asarray(x)\n",
        "    norm = np.linalg.norm(x, axis=1, keepdims=True) + 1e-12\n",
        "    return x / norm\n",
        "\n",
        "with torch.no_grad():\n",
        "    q_tokens = mbert_tok(query_bank, padding=True, truncation=True, max_length=16, return_tensors=\"pt\")\n",
        "    q_hidden = mbert_model(**q_tokens).last_hidden_state[:, 0, :].cpu().numpy()\n",
        "query_vectors = normalize_vec(q_hidden)\n",
        "\n",
        "def rule_patterns(text):\n",
        "    \"\"\"Extract patterns using regex rules.\"\"\"\n",
        "    matches = []\n",
        "    for match in pattern_regex.finditer(text):\n",
        "        pat = variant_to_pattern[match.group(1).lower()]\n",
        "        if pat not in matches:\n",
        "            matches.append(pat)\n",
        "    return matches\n",
        "\n",
        "def keybert_patterns(text):\n",
        "    \"\"\"Extract patterns using KeyBERT.\"\"\"\n",
        "    if not text:\n",
        "        return {}\n",
        "\n",
        "    try:\n",
        "        model = get_keybert_model()\n",
        "        kws = model.extract_keywords(\n",
        "            text,\n",
        "            candidates=candidate_terms,\n",
        "            keyphrase_ngram_range=(1,2),\n",
        "            stop_words=None,\n",
        "            use_mmr=True,\n",
        "            diversity=0.35,\n",
        "            top_n=KEYBERT_TOP_N\n",
        "        )\n",
        "        scores = {}\n",
        "        for term, score in kws:\n",
        "            pat = variant_to_pattern.get(term.lower().strip())\n",
        "            if pat:\n",
        "                scores[pat] = max(scores.get(pat, 0.0), float(score))\n",
        "        return scores\n",
        "    except Exception as e:\n",
        "        print(f\"\\n⚠️ KeyBERT pattern extraction failed: {e}\")\n",
        "        return {}\n",
        "\n",
        "def q_transform_distill(text):\n",
        "    \"\"\"Pattern distillation using query embeddings.\"\"\"\n",
        "    if not text:\n",
        "        return []\n",
        "\n",
        "    with torch.no_grad():\n",
        "        tokens = mbert_tok(text, padding=False, truncation=True, max_length=192, return_tensors=\"pt\")\n",
        "        hidden = mbert_model(**tokens).last_hidden_state[0].cpu().numpy()\n",
        "\n",
        "    token_vecs = normalize_vec(hidden)\n",
        "    attention = np.matmul(query_vectors, token_vecs.T)\n",
        "    salience = attention.max(axis=0)\n",
        "\n",
        "    token_list = mbert_tok.convert_ids_to_tokens(tokens[\"input_ids\"][0].cpu().numpy())\n",
        "    result = []\n",
        "\n",
        "    for tok, sal in zip(token_list, salience):\n",
        "        word = tok.replace(\"##\", \"\").replace(\"▁\", \"\").lower().strip()\n",
        "        if len(word) >=3 and sal >= PATTERN_THRESHOLD and word in variant_to_pattern:\n",
        "            result.append(variant_to_pattern[word])\n",
        "\n",
        "    return dedup_keep_order(result)\n",
        "\n",
        "def extract_patterns(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Extract final visual patterns using final_input_text.\"\"\"\n",
        "    print(\"\\n🔲 Starting Pattern Extraction...\")\n",
        "\n",
        "    if \"final_input_text\" not in df.columns:\n",
        "        if \"clean_name\" in df.columns and \"clean_desc\" in df.columns:\n",
        "            df[\"final_input_text\"] = (df[\"clean_name\"].fillna(\"\") + \" \" +\n",
        "                                      df[\"clean_desc\"].fillna(\"\")).str.strip()\n",
        "        else:\n",
        "            raise KeyError(\"final_input_text column is required for pattern extraction\")\n",
        "\n",
        "    df[\"text_input\"] = df[\"final_input_text\"].fillna(\"\").astype(str)\n",
        "\n",
        "    unique_texts = df[\"text_input\"].unique()\n",
        "    print(f\"🔍 Processing {len(unique_texts):,} unique text items...\")\n",
        "\n",
        "    cache = {}\n",
        "\n",
        "\n",
        "    for text in tqdm(unique_texts, desc=\"Extracting patterns\", unit=\"items\"):\n",
        "\n",
        "        rule = rule_patterns(text)\n",
        "\n",
        "\n",
        "        kb = []\n",
        "        text_lower = text.lower()\n",
        "        for term, pattern in variant_to_pattern.items():\n",
        "            if term in text_lower and pattern not in kb:\n",
        "                kb.append(pattern)\n",
        "\n",
        "        final = dedup_keep_order(rule + kb)\n",
        "\n",
        "        cache[text] = {\n",
        "            \"patterns_rule\": rule,\n",
        "            \"patterns_keybert\": kb,\n",
        "            \"patterns_final\": final\n",
        "        }\n",
        "\n",
        "    results = df[\"text_input\"].map(cache)\n",
        "\n",
        "    df[\"patterns_final\"] = results.map(lambda x: x[\"patterns_final\"] if x else [])\n",
        "    df[\"patterns_final_str\"] = df[\"patterns_final\"].map(lambda x: \"|\".join(x) if x else \"\")\n",
        "\n",
        "    df.drop(columns=[\"text_input\"], inplace=True, errors=\"ignore\")\n",
        "\n",
        "    patterns_found = df[\"patterns_final\"].map(len).sum()\n",
        "    print(f\"✓ Extracted {patterns_found:,} patterns from {len(df):,} items\")\n",
        "    print(f\"✓ Pattern extraction completed\\n\")\n",
        "\n",
        "    return df"
      ]
    },
