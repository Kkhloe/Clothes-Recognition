        "        \"bambú\"  # es\n",
        "    ],\n",
        "    \"suede\": [\n",
        "        \"suede\",\n",
        "        \"semiš\",  # cz\n",
        "        \"semiš\",  # sk\n",
        "        \"γυαλισμένο δέρμα\",  # gr\n",
        "        \"suede\",  # hu\n",
        "        \"suede\",  # si\n",
        "        \"suede\",  # lt\n",
        "        \"suede\",  # lv\n",
        "        \"suede\",  # hr\n",
        "        \"свеђ\",  # bg\n",
        "        \"suede\",  # ee\n",
        "        \"süet\",  # tr\n",
        "        \"suede\",  # ro\n",
        "        \"ante\"  # es\n",
        "    ],\n",
        "    \"fur\": [\n",
        "        \"fur\",\n",
        "        \"kožešina\",  # cz\n",
        "        \"kožušina\",  # sk\n",
        "        \"γούνα\",  # gr\n",
        "        \"kürt\",  # hu\n",
        "        \"krzno\",  # si\n",
        "        \"kailas\",  # lt\n",
        "        \"kaims\",  # lv\n",
        "        \"krzno\",  # hr\n",
        "        \"кожух\",  # bg\n",
        "        \"karus\",  # ee\n",
        "        \"kürk\",  # tr\n",
        "        \"blană\",  # ro\n",
        "        \"piel de pelo\"  # es\n",
        "    ]\n",
        "}\n",
        "\n",
        "variant_to_material = {}\n",
        "for canonical, variants in material_canonical.items():\n",
        "    for v in variants:\n",
        "        variant_to_material[v.lower()] = canonical\n",
        "\n",
        "sorted_variants = sorted(set(variant_to_material.keys()), key=len, reverse=True)\n",
        "material_pattern = re.compile(r\"(?<!\\\\w)(\" + \"|\".join([re.escape(v) for v in sorted_variants]) + r\")(?!\\\\w)\")\n",
        "pct_pattern = re.compile(r\"(\\\\d{1,3})\\\\s%\\\\s([\\\\w\\\\-\\\\u00C0-\\\\u024F\\\\u0370-\\\\u03FF\\\\u0400-\\\\u04FF]+)\")\n",
        "\n",
        "def extract_rule_materials(text):\n",
        "    \"\"\"Extract materials using keyword matching.\"\"\"\n",
        "    hits = []\n",
        "    for match in material_pattern.finditer(text):\n",
        "        mat = variant_to_material[match.group(1).lower()]\n",
        "        if mat not in hits:\n",
        "            hits.append(mat)\n",
        "    return hits\n",
        "\n",
        "def extract_composition_pairs(text):\n",
        "    \"\"\"Extract material percentage pairs.\"\"\"\n",
        "    pairs = []\n",
        "    for pct, token in pct_pattern.findall(text):\n",
        "        token = token.lower()\n",
        "        if token in variant_to_material:\n",
        "            pairs.append({\"material\": variant_to_material[token], \"pct\": int(pct)})\n",
        "\n",
        "    merged = {}\n",
        "    for item in pairs:\n",
        "        mat = item[\"material\"]\n",
        "        merged[mat] = max(merged.get(mat, 0), item[\"pct\"])\n",
        "\n",
        "    return [{\"material\": k, \"pct\": v} for k, v in sorted(merged.items(), key=lambda x: -x[1])]\n",
        "\n",
        "def init_ner():\n",
        "    \"\"\"Initialize NER model for material extraction.\"\"\"\n",
        "    if not ENABLE_NER:\n",
        "        return None\n",
        "    try:\n",
        "        tokenizer = XLMRobertaTokenizer.from_pretrained(NER_MODEL_NAME)\n",
        "        model = AutoModelForTokenClassification.from_pretrained(NER_MODEL_NAME)\n",
        "        return pipeline(\"token-classification\", model=model, tokenizer=tokenizer, aggregation_strategy=\"simple\")\n",
        "    except Exception:\n",
        "        try:\n",
        "            tokenizer = AutoTokenizer.from_pretrained(FALLBACK_NER_MODEL_NAME, use_fast=False)\n",
        "            model = AutoModelForTokenClassification.from_pretrained(FALLBACK_NER_MODEL_NAME)\n",
        "            return pipeline(\"token-classification\", model=model, tokenizer=tokenizer, aggregation_strategy=\"simple\")\n",
        "        except Exception:\n",
        "            return None\n",
        "\n",
        "def extract_ner_materials(text, ner_pipe):\n",
        "    \"\"\"Extract materials using NER model.\"\"\"\n",
        "    if not ner_pipe:\n",
        "        return []\n",
        "    entities = ner_pipe(text)\n",
        "    materials = []\n",
        "    for ent in entities:\n",
        "        word = str(ent.get(\"word\", \"\")).lower().strip().replace(\"▁\", \"\")\n",
        "        word = re.sub(r\"[^\\\\w\\\\-\\\\u00C0-\\\\u024F\\\\u0370-\\\\u03FF\\\\u0400-\\\\u04FF]\", \"\", word)\n",
        "        if word in variant_to_material and float(ent.get(\"score\", 0.0)) >= NER_SCORE_THRESHOLD:\n",
        "            materials.append(variant_to_material[word])\n",
        "    return dedup_keep_order(materials)\n",
        "\n",
        "def extract_materials_and_composition(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Extract materials and percentage composition using final_input_text.\"\"\"\n",
        "    print(\"\\n🧵 Starting Material Extraction...\")\n",
        "\n",
        "    if \"final_input_text\" not in df.columns:\n",
        "        if \"clean_name\" in df.columns and \"clean_desc\" in df.columns:\n",
        "            df[\"final_input_text\"] = (df[\"clean_name\"].fillna(\"\") + \" \" +\n",
        "                                      df[\"clean_desc\"].fillna(\"\")).str.strip()\n",
        "        else:\n",
        "            raise KeyError(\"final_input_text column is required for material extraction\")\n",
        "\n",
        "    df[\"text_input\"] = df[\"final_input_text\"].fillna(\"\").astype(str)\n",
        "\n",
        "    if \"geo\" not in df.columns:\n",
        "        df[\"geo\"] = \"\"\n",
        "\n",
        "    print(\"🤖 Initializing NER model...\")\n",
        "    ner_pipe = init_ner()\n",
        "    if ner_pipe and torch.cuda.is_available():\n",
        "        print(\"✓ NER model loaded on GPU\")\n",
        "\n",
        "    cache = {}\n",
        "    unique_pairs = df[[\"geo\", \"text_input\"]].drop_duplicates().itertuples(index=False, name=None)\n",
        "    unique_list = list(unique_pairs)\n",
        "\n",
        "    print(f\"🔍 Processing {len(unique_list):,} unique text items...\")\n",
        "\n",
        "    for geo, text in tqdm(unique_list, desc=\"Extracting materials\", unit=\"items\"):\n",
        "        rule_mats = extract_rule_materials(text)\n",
        "        ner_mats = extract_ner_materials(text, ner_pipe)\n",
        "        comp = extract_composition_pairs(text)\n",
        "        final_materials = dedup_keep_order(rule_mats + ner_mats)\n",
        "\n",
        "        cache[(geo, text)] = {\n",
        "            \"materials_rule\": rule_mats,\n",
        "            \"materials_ner\": ner_mats,\n",
        "            \"composition\": comp,\n",
        "            \"materials_final\": final_materials\n",
        "        }\n",
        "\n",
        "    keys = list(zip(df[\"geo\"].astype(str).tolist(), df[\"text_input\"].tolist()))\n",
        "    results = [cache.get(k, {\"materials_rule\": [], \"materials_ner\": [], \"composition\": [], \"materials_final\": []}) for k in keys]\n",
        "\n",
        "    df[\"materials_final\"] = [r[\"materials_final\"] for r in results]\n",
        "    df[\"composition\"] = [r[\"composition\"] for r in results]\n",
        "    df[\"materials_final_str\"] = df[\"materials_final\"].str.join(\"|\")\n",
        "    df[\"composition_str\"] = df[\"composition\"].map(lambda x: \"|\".join([f\"{i['material']}:{i['pct']}\" for i in x]))\n",
        "\n",
        "    df.drop(columns=[\"text_input\"], inplace=True, errors=\"ignore\")\n",
        "\n",
        "    # Statistics\n",
        "    material_count = sum(len(m) for m in df[\"materials_final\"])\n",
        "    print(f\"✓ Extracted {material_count:,} materials from {len(df):,} items\\n\")\n",
        "\n",
        "    return df\n"
      ]
    },
