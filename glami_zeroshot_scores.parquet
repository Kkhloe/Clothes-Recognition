      "source": [
        "# ====================== 7. Full Pipeline ======================\n",
        "def enrich_dataset(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Run full enrichment pipeline on dataset.\"\"\"\n",
        "    start_time = time.time()\n",
        "\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(f\"🚀 Starting Pipeline for {len(df):,} items\")\n",
        "    print(f\"📅 Start time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # Step 1: Style Prediction\n",
        "    df = predict_styles(df.copy())\n",
        "\n",
        "    # Step 2: Material Extraction\n",
        "    df = extract_materials_and_composition(df)\n",
        "\n",
        "    # Step 3: Color Extraction\n",
        "    df = extract_colors(df)\n",
        "\n",
        "    # Step 4: Pattern Extraction\n",
        "    df = extract_patterns(df)\n",
        "\n",
        "\n",
        "    keep_columns = [\n",
        "        \"item_id\", \"geo\", \"final_input_text\", \"main_category_15\", \"predicted_category\", \"label\",\n",
        "        \"pred_style\", \"pred_conf\",\n",
        "        \"primary_color\", \"colors_str\", \"primary_color_highconf\", \"colors_highconf_str\",\n",
        "        \"materials_final_str\", \"composition_str\",\n",
        "        \"patterns_final_str\"\n",
        "    ]\n",
        "\n",
        "    elapsed = time.time() - start_time\n",
        "    print(\"=\"*60)\n",
        "    print(f\"✅ Pipeline completed in {timedelta(seconds=int(elapsed))}\")\n",
        "    print(f\"📊 Processed {len(df):,} items ({len(df)/elapsed:.1f} items/sec)\")\n",
        "    print(\"=\"*60 + \"\\n\")\n",
        "\n",
        "    return df[[c for c in keep_columns if c in df.columns]].copy()\n",
        "\n",
        "def main():\n",
        "    \"\"\"Main execution function.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"👕 Fashion Attribute Extraction Pipeline\")\n",
        "    print(f\"💻 Device: {DEVICE}\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "\n",
        "    # Process training data\n",
        "    if os.path.exists(INPUT_TRAIN):\n",
        "        print(f\"\\n📂 Reading training data: {INPUT_TRAIN}\")\n",
        "        df_train = read_csv_robust(INPUT_TRAIN)\n",
        "        print(f\"✓ Loaded {len(df_train):,} training samples\")\n",
        "\n",
        "        enriched_train = enrich_dataset(df_train)\n",
        "\n",
        "        out_train = os.path.join(OUTPUT_DIR, \"enriched_train.csv\")\n",
        "        print(f\"💾 Saving to: {out_train}\")\n",
        "        enriched_train.to_csv(out_train, index=False, encoding=\"utf-8-sig\")\n",
        "        print(f\"✓ Training data saved successfully!\")\n",
        "    else:\n",
        "        print(f\"⚠️ Training file not found: {INPUT_TRAIN}\")\n",
        "\n",
        "    # Process test data\n",
        "    if os.path.exists(INPUT_TEST):\n",
        "        print(f\"\\n📂 Reading test data: {INPUT_TEST}\")\n",
        "        df_test = read_csv_robust(INPUT_TEST)\n",
        "        print(f\"✓ Loaded {len(df_test):,} test samples\")\n",
        "\n",
        "        enriched_test = enrich_dataset(df_test)\n",
        "\n",
        "        out_test = os.path.join(OUTPUT_DIR, \"enriched_test.csv\")\n",
        "        print(f\"💾 Saving to: {out_test}\")\n",
        "        enriched_test.to_csv(out_test, index=False, encoding=\"utf-8-sig\")\n",
        "        print(f\"✓ Test data saved successfully!\")\n",
        "    else:\n",
        "        print(f\"⚠️ Test file not found: {INPUT_TEST}\")\n",
        "\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"🎉 Pipeline completed successfully!\")\n",
        "    print(f\"📁 Results saved in: {OUTPUT_DIR}/\")\n",
        "    print(\"=\"*60 + \"\\n\")\n",
        "\n",
        "    # GPU memory cleanup\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.empty_cache()\n",
        "        print(\"🧹 GPU memory cleared\")\n",
        "\n",
        "# Run pipeline\n",
        "if __name__ == \"__main__\":\n",
        "    try:\n",
        "        main()\n",
        "    except KeyboardInterrupt:\n",
        "        print(\"\\n⚠️ Pipeline interrupted by user\")\n",
        "        if torch.cuda.is_available():\n",
        "            torch.cuda.empty_cache()\n",
        "    except Exception as e:\n",
        "        print(f\"\\n❌ Error: {str(e)}\")\n",
        "        traceback.print_exc()\n",
        "        if torch.cuda.is_available():\n",
        "            torch.cuda.empty_cache()"
      ]
    }
  ],
