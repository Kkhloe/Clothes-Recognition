      "source": [
        "# Auto-install missing packages\n",
        "def ensure_package(pkg, pipname=None):\n",
        "    try:\n",
        "        __import__(pkg)\n",
        "    except Exception:\n",
        "        print(f\"Installing {pipname or pkg}...\")\n",
        "        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pipname or pkg])\n",
        "\n",
        "required_packages = [\n",
        "    (\"pandas\", None),\n",
        "    (\"ftfy\", None),\n",
        "    (\"tqdm\", None),\n",
        "    (\"deep_translator\", \"deep-translator\"),\n",
        "    (\"unidecode\", None),\n",
        "    (\"sentence_transformers\", \"sentence-transformers\"),\n",
        "    (\"transformers\", None),\n",
        "    (\"torch\", None),\n",
        "    (\"keybert\", None),\n",
        "    (\"numpy\", None),\n",
        "    (\"scikit_learn\", \"scikit-learn\")\n",
        "]\n",
        "\n",
        "print(\"\\n📦 Checking required packages...\")\n",
        "for pkg, pip_name in tqdm(required_packages, desc=\"Checking packages\"):\n",
        "    ensure_package(pkg, pip_name)\n",
        "print(\"✓ All packages ready\\n\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 21,
